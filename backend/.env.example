# ─────────────────────────────────────────────────────────────
# Backend configuration (FastAPI). Copy to `.env` and edit.
#   cp .env.example .env
# Every value below has a sensible default in app/config.py,
# so the API runs with NO .env file at all. Override as needed.
# ─────────────────────────────────────────────────────────────

# --- Database (OPTIONAL) ------------------------------------------------
# Leave empty to run fully in-memory (no persistence). The API still
# works — it just won't store history across restarts.
# To enable persistence, point at any PostgreSQL instance:
#   DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# --- CORS ---------------------------------------------------------------
# Comma/JSON list of origins allowed to call this API.
# Defaults already include http://localhost:3000 and https://*.vercel.app.
# Add your own frontend origin here if it differs.
# CORS_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]

# --- Location (Karachi by default) -------------------------------------
# LATITUDE=24.8608
# LONGITUDE=67.0104

# --- Model --------------------------------------------------------------
# N_ESTIMATORS=100
# MAX_DEPTH=5
# FLOOD_MODEL_PATH=app/data/flood_model.joblib

# --- Open-Meteo (free, no key required) --------------------------------
# API_URL=https://api.open-meteo.com/v1/forecast
# PAST_DAYS=92

# --- Scheduler / retraining --------------------------------------------
# PREDICTION_INTERVAL_MINUTES=60
# HISTORY_RETENTION_DAYS=90
# RETRAIN_EVERY_N_CYCLES=24
# MIN_OBSERVATIONS_FOR_RETRAIN=100
# BACKFILL_DAYS=92
