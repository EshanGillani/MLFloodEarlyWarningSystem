# ─────────────────────────────────────────────────────────────
# Frontend configuration (Next.js). Copy to `.env.local` and edit.
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────

# Base URL of the backend API.
# - Local development (backend running on the default port): leave as-is.
# - Production: set this to your deployed backend URL, e.g.
#     NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
#
# NOTE: this must be set at BUILD time. On Vercel, add it under
# Project → Settings → Environment Variables, then redeploy.
NEXT_PUBLIC_API_URL=http://localhost:8000
